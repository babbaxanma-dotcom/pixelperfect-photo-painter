# =============================================================================
# AB Bouw Group — environment variables
# Kopieer dit bestand naar `.env` en vul de waardes in. `.env` is git-ignored.
# Na elke wijziging in `.env`: stop en herstart `npm run dev` / rebuild.
# =============================================================================

# --- GoHighLevel Inbound Webhook (Norvo subaccount) -------------------------
# 1) In GHL → Automations → Workflows → "Website formulier"
# 2) Trigger: Inbound Webhook → "Add new" → kopieer de webhook URL hier.
# 3) Test: zet de workflow live, vul het contactformulier op de site in.
VITE_GHL_WEBHOOK_URL=

# --- Web3Forms fallback (gratis 1000 emails/mnd, gewoon backup) -------------
# Account maken: https://web3forms.com (geen registratie, alleen email
# bevestigen). Geeft je een access_key.
VITE_WEB3FORMS_KEY=
VITE_LEAD_EMAIL_FALLBACK_TO=info@abgroep.be

# --- Google Analytics 4 -----------------------------------------------------
# Maken in https://analytics.google.com → Admin → Data streams → Web.
# Measurement ID begint met G-...
VITE_GA4_ID=

# --- Google Ads conversions -------------------------------------------------
# Maken in https://ads.google.com → Tools → Conversions.
# Account ID begint met AW-... ; per conversie krijg je een label (random string).
VITE_GADS_ID=
VITE_GADS_CONVERSION_LABEL_FORM=
VITE_GADS_CONVERSION_LABEL_CALL=
VITE_GADS_CONVERSION_LABEL_NEWS=

# --- Site basis (voor sitemap + canonical) ---------------------------------
VITE_SITE_URL=https://abgroep.be
